# =============================================================================
# League Prediction Market — Environment Template
# Copy to `.env` and fill in. The app runs in DEMO mode if DATABASE_URL is unset.
# =============================================================================

# --- Database (Supabase Postgres) -------------------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/league_market?schema=public"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/league_market?schema=public"

# --- Supabase Auth ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose to the client. Used by admin/service operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Compliance gating ------------------------------------------------------
# Real-money functionality is DISABLED by default and must remain so until a
# documented legal/compliance review explicitly enables it. Leave as "false".
ENABLE_REAL_MONEY="false"

# Starting play-credit grant for new league members (in whole credits).
DEFAULT_STARTING_CREDITS="10000"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="League Markets"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
